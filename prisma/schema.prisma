generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Organization {
  id               String           @id @default(cuid())
  name             String
  slug             String           @unique
  stripeCustomerId String?          @unique
  subscriptionTier String           @default("FREE")
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  walletBalance    Float            @default(0.0)
  aiTransactions   AITransaction[]
  agents           Agent[]
  approvals        Approval[]
  auditLogs        AuditLog[]
  decisions        Decision[]
  metricSnapshots  MetricSnapshot[]
  policies         Policy[]
  risks            Risk[]
  spendLogs        SpendLog[]
  users            User[]
}

model User {
  id                String       @id @default(cuid())
  organizationId    String
  email             String       @unique
  passwordHash      String?
  role              String       @default("VIEWER")
  createdAt         DateTime     @default(now())
  approvalsReviewed Approval[]   @relation("ApprovalReviewer")
  auditLogs         AuditLog[]
  risksOwned        Risk[]
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

model Agent {
  id               String          @id @default(cuid())
  organizationId   String
  name             String
  environment      String
  agentToken       String          @unique
  status           String          @default("ACTIVE")
  trustCertificate String?         @unique
  walletBalance    Float           @default(0.0)
  createdAt        DateTime        @default(now())
  transactions     AITransaction[]
  organization     Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  decisions        Decision[]
  policies         Policy[]
  spendLogs        SpendLog[]

  @@index([organizationId])
  @@index([agentToken])
}

model Policy {
  id             String       @id @default(cuid())
  organizationId String
  agentId        String?
  action         String
  resource       String
  condition      String
  effect         String
  riskLevel      String       @default("MEDIUM")
  createdAt      DateTime     @default(now())
  decisions      Decision[]
  agent          Agent?       @relation(fields: [agentId], references: [id])
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([agentId])
}

model Decision {
  id             String       @id @default(cuid())
  organizationId String
  agentId        String
  policyId       String?
  actionType     String
  resourceJson   String
  contextJson    String
  decision       String
  reason         String
  createdAt      DateTime     @default(now())
  approval       Approval?
  agent          Agent        @relation(fields: [agentId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  policy         Policy?      @relation(fields: [policyId], references: [id])

  @@index([organizationId])
  @@index([agentId])
  @@index([organizationId, createdAt])
}

model AITransaction {
  id             String       @id @default(cuid())
  organizationId String
  agentId        String
  type           String
  amount         Float
  currency       String       @default("USD")
  counterpartyId String?
  status         String       @default("COMPLETED")
  evidenceId     String?
  createdAt      DateTime     @default(now())
  agent          Agent        @relation(fields: [agentId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([agentId])
  @@index([organizationId, createdAt])
}

model Approval {
  id             String       @id @default(cuid())
  organizationId String
  decisionId     String       @unique
  status         String       @default("PENDING")
  reviewerId     String?
  approvedAt     DateTime?
  createdAt      DateTime     @default(now())
  decision       Decision     @relation(fields: [decisionId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  reviewer       User?        @relation("ApprovalReviewer", fields: [reviewerId], references: [id])

  @@index([organizationId])
  @@index([organizationId, status])
}

model Risk {
  id             String       @id @default(cuid())
  organizationId String
  title          String
  description    String?
  severity       String       @default("MEDIUM")
  score          Float        @default(0.0)
  status         String       @default("OPEN")
  ownerId        String?
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  owner          User?        @relation(fields: [ownerId], references: [id])

  @@index([organizationId])
  @@index([organizationId, createdAt])
}

model AuditLog {
  id             String       @id @default(cuid())
  organizationId String
  userId         String?
  action         String
  resource       String
  metadataJson   String?
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User?        @relation(fields: [userId], references: [id])

  @@index([organizationId])
}

model MetricSnapshot {
  id              String       @id @default(cuid())
  organizationId  String
  aiSpend         Float        @default(0)
  aiSavings       Float        @default(0)
  roi             Float        @default(0)
  decisions       Int          @default(0)
  approvals       Int          @default(0)
  risksOpen       Int          @default(0)
  complianceScore Float        @default(100.0)
  createdAt       DateTime     @default(now())
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([organizationId, createdAt])
}

model SpendLog {
  id             String       @id @default(cuid())
  organizationId String
  agentId        String
  model          String
  tokensUsed     Int
  costUsd        Float
  action         String
  createdAt      DateTime     @default(now())
  agent          Agent        @relation(fields: [agentId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([organizationId, createdAt])
}
