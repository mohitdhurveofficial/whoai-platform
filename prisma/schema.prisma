generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Organization {
  id                   String               @id @default(uuid())
  name                 String
  slug                 String               @unique
  tier                 OrgTier              @default(STARTUP)
  kmsKeyArn            String?
  enforceSso           Boolean              @default(false)
  dailyBudget          Decimal              @default(0) @db.Decimal(18, 4)
  monthlyBudget        Decimal              @default(0) @db.Decimal(18, 4)
  currentDailySpend    Decimal              @default(0) @db.Decimal(18, 4)
  currentMonthlySpend  Decimal              @default(0) @db.Decimal(18, 4)
  pauseReason          String?
  pausedAt             DateTime?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  stripeCustomerId     String?              @unique
  stripeSubscriptionId String?              @unique
  subscriptionStatus   String               @default("FREE")
  subscriptionTier     String               @default("FREE")
  currentPeriodEnd     DateTime?
  status               String               @default("ACTIVE")
  activityLogs         ActivityLog[]
  agents               Agent[]
  alerts               Alert[]
  ApiKey               ApiKey[]
  budgetViolations     BudgetViolation[]
  policies             Policy[]
  requestLogs          RequestLog[]
  spendLogs            SpendLog[]
  subscription         Subscription?
  usageMetrics         UsageMetrics[]
  users                User[]
  providerCredentials  ProviderCredential[]
}

model User {
  id             String       @id @default(uuid())
  email          String       @unique
  role           String       @default("DEVELOPER")
  organizationId String
  createdAt      DateTime     @default(now())
  fullName       String?
  organization   Organization @relation(fields: [organizationId], references: [id])
}

model Agent {
  id                  String            @id @default(uuid())
  name                String
  organizationId      String
  clientId            String            @unique
  clientSecret        String
  apiKey              String            @unique
  scopes              String[]          @default(["llm:read", "llm:write"])
  status              AgentStatus       @default(ACTIVE)
  dailyBudget         Decimal           @db.Decimal(18, 4)
  monthlyBudget       Decimal           @db.Decimal(18, 4)
  currentDailySpend   Decimal           @default(0) @db.Decimal(18, 4)
  currentMonthlySpend Decimal           @default(0) @db.Decimal(18, 4)
  pauseReason         String?
  pausedAt            DateTime?
  pausedBy            String?
  createdAt           DateTime          @default(now())
  activityLogs        ActivityLog[]
  organization        Organization      @relation(fields: [organizationId], references: [id])
  alerts              Alert[]
  budgetViolations    BudgetViolation[]
  policies            Policy[]
  requestLogs         RequestLog[]
  spendLogs           SpendLog[]
  usageMetrics        UsageMetrics[]

  @@index([organizationId, status])
}

model Policy {
  id             String       @id @default(uuid())
  name           String
  organizationId String
  agentId        String?
  ruleDsl        String
  action         PolicyAction @default(ALLOW)
  priority       Int          @default(100)
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())
  agent          Agent?       @relation(fields: [agentId], references: [id])
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId, priority])
}

model SpendLog {
  id             String       @id @default(uuid())
  agentId        String
  organizationId String
  model          String
  provider       String
  tokensIn       Int
  tokensOut      Int
  cost           Decimal      @db.Decimal(18, 8)
  metadata       Json?
  createdAt      DateTime     @default(now())
  agent          Agent        @relation(fields: [agentId], references: [id])
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId, createdAt])
}

model ActivityLog {
  id             String       @id @default(uuid())
  timestamp      DateTime     @default(now())
  organizationId String
  agentId        String?
  action         String
  status         String?
  metadata       Json?
  createdAt      DateTime     @default(now())
  agent          Agent?       @relation(fields: [agentId], references: [id])
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId, timestamp])
}

model Subscription {
  id               String       @id @default(uuid())
  organizationId   String       @unique
  stripeId         String?      @unique
  plan             String       @default("FREE")
  status           String       @default("ACTIVE")
  currentPeriodEnd DateTime?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  organization     Organization @relation(fields: [organizationId], references: [id])
}

model RequestLog {
  id                 String       @id @default(uuid())
  timestamp          DateTime     @default(now())
  agentId            String
  organizationId     String
  provider           String
  model              String
  requestPayloadSize Int          @default(0)
  statusCode         Int          @default(200)
  latencyMs          Int          @default(0)
  ipAddress          String?
  createdAt          DateTime     @default(now())
  agent              Agent        @relation(fields: [agentId], references: [id])
  organization       Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId, timestamp])
}

model UsageMetrics {
  id             String       @id @default(uuid())
  agentId        String
  organizationId String
  date           DateTime     @default(now()) @db.Date
  totalRequests  Int          @default(0)
  totalTokens    Int          @default(0)
  totalCost      Decimal      @default(0) @db.Decimal(18, 4)
  agent          Agent        @relation(fields: [agentId], references: [id])
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@unique([agentId, date])
  @@index([organizationId, date])
}

model Alert {
  id             String       @id @default(uuid()) @db.VarChar
  organizationId String       @db.VarChar
  agentId        String?      @db.VarChar
  type           String       @db.VarChar
  severity       String?      @db.VarChar
  title          String       @db.VarChar
  message        String       @db.VarChar
  metadata       Json?        @db.Json
  resolved       Boolean?
  createdAt      DateTime?    @db.Timestamp(6)
  agent          Agent?       @relation(fields: [agentId], references: [id], onUpdate: NoAction)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model BudgetViolation {
  id             String       @id @default(uuid())
  organizationId String
  agentId        String?
  violationType  String
  currentSpend   Decimal      @db.Decimal(18, 4)
  budgetLimit    Decimal      @db.Decimal(18, 4)
  timestamp      DateTime     @default(now())
  agent          Agent?       @relation(fields: [agentId], references: [id])
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId, timestamp])
}

model ApiKey {
  id             String       @id @default(cuid())
  organizationId String
  name           String
  keyHash        String
  lastUsedAt     DateTime?
  revoked        Boolean      @default(false)
  createdAt      DateTime     @default(now())
  Organization   Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
}

enum OrgTier {
  STARTUP
  GROWTH
  ENTERPRISE
  VPC
  FREE
}

enum AgentStatus {
  ACTIVE
  PAUSED
  QUARANTINED
  TERMINATED
}

enum PolicyAction {
  ALLOW
  DENY
  REQUIRE_APPROVAL
  FLAG
}

enum AlertStatus {
  OPEN
  ACKNOWLEDGED
  RESOLVED
}

model ProviderCredential {
  id              String       @id @default(uuid())
  organizationId  String
  provider        String
  encryptedApiKey String       @db.Text
  status          String       @default("CONNECTED")
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, provider])
}
