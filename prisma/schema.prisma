generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Organization {
  id           String         @id @default(uuid())
  name         String
  slug         String         @unique
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  enforceSso   Boolean        @default(false)
  kmsKeyArn    String?
  tier         OrgTier        @default(STARTUP)
  activityLogs ActivityLog[]
  agents       Agent[]
  alerts       Alert[]
  policies     Policy[]
  requestLogs  RequestLog[]
  spendLogs    SpendLog[]
  subscription Subscription?
  usageMetrics UsageMetrics[]
  users        User[]
}

model User {
  id             String       @id @default(uuid())
  organizationId String
  email          String       @unique
  createdAt      DateTime     @default(now())
  role           String       @default("DEVELOPER")
  fullName       String?
  organization   Organization @relation(fields: [organizationId], references: [id])
}

model Agent {
  id                String         @id @default(uuid())
  organizationId    String
  name              String
  createdAt         DateTime       @default(now())
  status            AgentStatus    @default(ACTIVE)
  apiKey            String         @unique
  clientId          String         @unique
  clientSecret      String

  currentDailySpend Decimal        @default(0) @db.Decimal(18, 4)
  dailyBudget       Decimal        @db.Decimal(18, 4)
  monthlyBudget     Decimal        @db.Decimal(18, 4)

  pauseReason       String?
  pausedAt          DateTime?
  pausedBy          String?

  scopes            String[]       @default(["llm:read", "llm:write"])

  activityLogs      ActivityLog[]
  organization      Organization   @relation(fields: [organizationId], references: [id])
  alerts            Alert[]
  policies          Policy[]
  requestLogs       RequestLog[]
  spendLogs         SpendLog[]
  usageMetrics      UsageMetrics[]

  @@index([organizationId, status])
}

model Policy {
  id             String       @id @default(uuid())
  name           String
  organizationId String
  agentId        String?
  ruleDsl        String
  action         PolicyAction @default(ALLOW)
  priority       Int          @default(100)
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())
  agent          Agent?       @relation(fields: [agentId], references: [id])
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId, priority])
}

model SpendLog {
  id             String       @id @default(uuid())
  organizationId String
  model          String
  createdAt      DateTime     @default(now())
  agentId        String
  cost           Decimal      @db.Decimal(18, 8)
  metadata       Json?
  provider       String
  tokensIn       Int
  tokensOut      Int
  agent          Agent        @relation(fields: [agentId], references: [id])
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId, createdAt])
}

model ActivityLog {
  id             String       @id @default(uuid())
  organizationId String
  action         String
  createdAt      DateTime     @default(now())
  agentId        String?
  metadata       Json?
  status         String?
  timestamp      DateTime     @default(now())
  agent          Agent?       @relation(fields: [agentId], references: [id])
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId, timestamp])
}

model Subscription {
  id               String       @id @default(uuid())
  organizationId   String       @unique
  stripeId         String?      @unique
  plan             String       @default("FREE")
  status           String       @default("ACTIVE")
  currentPeriodEnd DateTime?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  organization     Organization @relation(fields: [organizationId], references: [id])
}

model RequestLog {
  id                 String       @id @default(uuid())
  timestamp          DateTime     @default(now())
  agentId            String
  organizationId     String
  provider           String
  model              String
  requestPayloadSize Int          @default(0)
  statusCode         Int          @default(200)
  latencyMs          Int          @default(0)
  ipAddress          String?
  createdAt          DateTime     @default(now())
  agent              Agent        @relation(fields: [agentId], references: [id])
  organization       Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId, timestamp])
}

model UsageMetrics {
  id             String       @id @default(uuid())
  agentId        String
  organizationId String
  date           DateTime     @default(now()) @db.Date
  totalRequests  Int          @default(0)
  totalTokens    Int          @default(0)
  totalCost      Decimal      @default(0) @db.Decimal(18, 4)
  agent          Agent        @relation(fields: [agentId], references: [id])
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@unique([agentId, date])
  @@index([organizationId, date])
}

model Alert {
  id             String       @id @default(uuid()) @db.VarChar
  organizationId String       @db.VarChar
  agentId        String?      @db.VarChar
  type           String       @db.VarChar
  severity       String?      @db.VarChar
  title          String       @db.VarChar
  message        String       @db.VarChar
  metadata       Json?        @db.Json
  resolved       Boolean?
  createdAt      DateTime?    @db.Timestamp(6)
  agent          Agent?       @relation(fields: [agentId], references: [id], onUpdate: NoAction)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

enum OrgTier {
  STARTUP
  GROWTH
  ENTERPRISE
  VPC
}

enum AgentStatus {
  ACTIVE
  PAUSED
  QUARANTINED
  TERMINATED
}

enum PolicyAction {
  ALLOW
  DENY
  REQUIRE_APPROVAL
  FLAG
}
